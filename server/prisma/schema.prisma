generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model cliente {
  id_cliente     Int            @id @default(autoincrement())
  nombre         String         @db.VarChar(100)
  tipo_documento String?        @db.VarChar(20)
  cedula         String?        @unique @db.VarChar(20)
  telefono       String?        @db.VarChar(20)
  correo         String?        @unique @db.VarChar(100)
  direccion      String?        @db.VarChar(255)
  usuarios       usuario[]

  agendaciones   agendamiento[]
  mascotas       mascotas[]
  ventas         ventas[]
}

model mascotas {
  id_mascota           Int                  @id @default(autoincrement())
  nombre               String               @db.VarChar(50)
  especie              String?              @db.VarChar(50)
  raza                 String?              @db.VarChar(50)
  edad                 Int?
  fecha_nacimiento     DateTime?            @db.Date
  foto                 String?              @db.Text
  observaciones        String?              @db.Text
  vacunas              String?              @db.Text
  fecha_ultima_vacuna  DateTime?            @db.Date
  fecha_desparasitacion DateTime?            @db.Date
  peso                 Float?
  id_cliente           Int
  historial_mascotas   historial_mascotas[]
  cliente              cliente              @relation(fields: [id_cliente], references: [id_cliente])
}

model historial_mascotas {
  id_historial           Int       @id @default(autoincrement())
  id_mascota             Int
  fecha                  DateTime? @db.Date
  descripcion            String?   @db.Text
  hora                   String?   @db.VarChar(10)
  tipoVisita             String?   @db.Text
  veterinario            String?   @db.VarChar(100)
  motivoConsulta         String?   @db.Text
  sintomas               String?   @db.Text
  diagnostico            String?   @db.Text
  tratamiento            String?   @db.Text
  medicamentos           String?   @db.Text
  examenes               String?   @db.Text
  peso                   Float?
  temperatura            Float?
  frecuenciaCardiaca     Int?
  frecuenciaRespiratoria Int?
  estado                 String?   @db.VarChar(20)
  proximaCita            DateTime? @db.Date
  observaciones          String?   @db.Text
  costo                  Decimal?  @db.Decimal(10, 2)
  vacunasAplicadas       String?   @db.Text
  receta                 String?   @db.Text
  mascota                mascotas  @relation(fields: [id_mascota], references: [id_mascota])
}

model empleado {
  id_empleado    Int            @id @default(autoincrement())
  tipo_documento String?        @db.VarChar(20)
  cedula         String?        @unique @db.VarChar(20)
  nombre         String         @db.VarChar(100)
  correo         String?        @unique @db.VarChar(100)
  telefono       String?        @db.VarChar(20)
  direccion      String?        @db.VarChar(255)
  cargo          String?        @db.VarChar(50)
  profesion      String?        @db.VarChar(100)
  especialidad   String?        @db.VarChar(100)
  observaciones  String?        @db.Text
  experiencia    String?        @db.Text
  usuarios       usuario[]

  agendaciones   agendamiento[]
  horarios       horario[]
}

model usuario {
  id_usuario           Int       @id @default(autoincrement())
  nombre_usuario       String    @db.VarChar(50)
  contrasena           String    @db.VarChar(100)
  correo               String?   @unique @db.VarChar(100)
  cedula               String?   @unique @db.VarChar(20)
  tipo_documento       String?   @db.VarChar(20)
  
  // Auditing & State
  activo               Boolean?  @default(true)
  estado               String?   @default("activo") @db.VarChar(20) // activo, inactivo, bloqueado
  fecha_creacion       DateTime? @default(now())
  fecha_actualizacion  DateTime? @updatedAt
  usuario_creador      Int?

  // Authorization and Profiles
  nombre_completo      String?   @db.VarChar(150)
  grupo_usuario        String?   @db.VarChar(50)
  permisos_especificos String?   @db.Text

  // Security
  pregunta_seguridad   String?   @db.VarChar(255)
  respuesta_seguridad  String?   @db.VarChar(255)
  token_recuperacion   String?   @db.VarChar(255)

  id_rol               Int
  rol                  roles     @relation(fields: [id_rol], references: [id_rol])
  id_cliente           Int?
  id_empleado          Int?

  cliente              cliente?  @relation(fields: [id_cliente], references: [id_cliente])
  empleado             empleado? @relation(fields: [id_empleado], references: [id_empleado])
}

model roles {
  id_rol         Int              @id @default(autoincrement())
  nombre_rol     String           @db.VarChar(50)
  activo         Boolean?         @default(true)
  roles_permisos roles_permisos[]
  usuarios       usuario[]
}

model permisos {
  id_permiso     Int              @id @default(autoincrement())
  descripcion    String?          @db.VarChar(100)
  roles_permisos roles_permisos[]
}

model roles_permisos {
  id_rol     Int
  id_permiso Int
  permiso    permisos @relation(fields: [id_permiso], references: [id_permiso])
  rol        roles    @relation(fields: [id_rol], references: [id_rol])

  @@id([id_rol, id_permiso])
}

model servicios {
  id_servicio            Int                      @id @default(autoincrement())
  nombre_servicio        String                   @db.VarChar(100)
  precio                 Decimal?                 @db.Decimal(10, 2)
  descripcion            String?                  @db.Text
  estado                 String?                  @default("activo") @db.VarChar(20)
  agendamiento_servicios agendamiento_servicios[]
  venta_servicios        venta_servicios[]
}

model ventas {
  id_venta        Int               @id @default(autoincrement())
  fecha           DateTime?         @db.Date
  total           Decimal?          @db.Decimal(10, 2)
  id_cliente      Int
  estado          String?           @default("aprobada") @db.VarChar(20)
  venta_servicios venta_servicios[]
  cliente         cliente           @relation(fields: [id_cliente], references: [id_cliente])
}

model venta_servicios {
  id_venta    Int
  id_servicio Int
  cantidad    Int?
  servicio    servicios @relation(fields: [id_servicio], references: [id_servicio])
  venta       ventas    @relation(fields: [id_venta], references: [id_venta])

  @@id([id_venta, id_servicio])
}

model agendamiento {
  id_agendamiento        Int                      @id @default(autoincrement())
  fecha                  DateTime?                @db.Date
  hora                   DateTime?                @db.Time
  id_cliente             Int
  id_empleado            Int
  cliente                cliente                  @relation(fields: [id_cliente], references: [id_cliente])
  empleado               empleado                 @relation(fields: [id_empleado], references: [id_empleado])
  agendamiento_servicios agendamiento_servicios[]
  estado                 String?                  @default("activa") @db.VarChar(20)
}

model agendamiento_servicios {
  id_agendamiento Int
  id_servicio     Int
  agendamiento    agendamiento @relation(fields: [id_agendamiento], references: [id_agendamiento])
  servicio        servicios    @relation(fields: [id_servicio], references: [id_servicio])

  @@id([id_agendamiento, id_servicio])
}

model horario {
  id_horario  Int       @id @default(autoincrement())
  id_empleado Int
  dia_semana  String?   @db.VarChar(20)
  hora_inicio DateTime? @db.Time
  hora_fin    DateTime? @db.Time
  disponible  Boolean?  @default(true)
  empleado    empleado  @relation(fields: [id_empleado], references: [id_empleado])
}
